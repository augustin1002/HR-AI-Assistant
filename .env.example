# Copy this file to .env and fill in the values you need.

# --- LLM provider: mock | openai | anthropic | gemini | ollama ---
# Choose one provider and uncomment its corresponding block:

LLM_PROVIDER=mock

# LLM_PROVIDER=openai
# OPENAI_API_KEY=your_openai_api_key_here

# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# LLM_PROVIDER=gemini
# GEMINI_API_KEY=your_gemini_api_key_here

# LLM_PROVIDER=ollama
# OLLAMA_MODEL=llama3

# --- Embeddings backend: auto | st | tfidf ---
# auto = try sentence-transformers, fall back to TF-IDF if unavailable
EMBEDDING_BACKEND=auto

# --- UI display style: claude | chatgpt ---
# claude = darker, modern assistant-style theme
# chatgpt = lighter, polished chat interface
DISPLAY_STYLE=claude
